{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noobDB",
  "version": "0.1.0",
  "identifier": "dev.noobdb.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "noobDB",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNUU1NURGQ0FBNEY4MjgKUldRbytLVEszMVZlekRETXlCa24wc2ZtdTFWeWJYYkdWQjk2ZG1DdWNnZTFtUkUxQ2s3ZG1rTXEK",
      "endpoints": [
        "https://github.com/noan98/noobDB/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English", "Japanese"]
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Rust MySQL client with SSH tunnel",
    "longDescription": "A lightweight desktop MySQL client built with Rust + Tauri, supporting SSH tunnel connections."
  }
}
