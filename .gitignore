# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#.idea/

# Node / Vite frontend
node_modules/
dist/
dist-ssr/
.vite/
*.local
.DS_Store
*.tsbuildinfo

# Coverage reports (Vitest v8 / cargo-llvm-cov)
coverage/
src-tauri/lcov.info

# ビジュアル回帰 (#306) の失敗時アーティファクト。ベースライン PNG 本体
# (__screenshots__/.../<name>-chromium-linux.png) はコミットするが、不一致時に
# Vitest が出力する実測/差分画像はコミットしない (デバッグ用の一時生成物)。
**/__screenshots__/**/*-actual.png
**/__screenshots__/**/*-diff.png

# シナリオテスト (#564) はベースラインを持たないため、テスト失敗時に Vitest が
# 自動保存するスクリーンショットごとコミットしない (デバッグ用の一時生成物)。
src/__tests__/browser/__screenshots__/scenarios.browser.test.tsx/

# a11y テスト (#603) も同様にベースラインを持たない (axe の判定のみ)。
src/__tests__/browser/__screenshots__/a11y.browser.test.tsx/
.vitest-attachments/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Claude Code agent worktrees (transient)
.claude/worktrees/
